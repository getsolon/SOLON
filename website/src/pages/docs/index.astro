---
import Base from '../../layouts/Base.astro'
import Navbar from '../../components/Navbar.astro'
import CodeBlock from '../../components/CodeBlock.astro'
import Footer from '../../components/Footer.astro'
---

<Base title="Docs — Solon">
  <Navbar current="/docs" />

  <div class="max-w-4xl mx-auto px-6 pt-16 pb-32">
    <div class="grid grid-cols-1 md:grid-cols-[200px_1fr] gap-12">

      {/* Sidebar */}
      <aside class="text-sm">
        <h4 class="text-xs uppercase tracking-wider text-gray-400 dark:text-gray-600 font-semibold mb-3">Getting Started</h4>
        <a href="/docs" class="block py-1.5 text-gray-900 dark:text-white font-medium">Quickstart</a>
        <a href="/docs/api" class="block py-1.5 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white">API Reference</a>
        <a href="/docs/cli" class="block py-1.5 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white">CLI Reference</a>
      </aside>

      {/* Content */}
      <div class="prose-container">
        <h1 class="text-3xl font-bold tracking-tight mb-8">Quickstart</h1>

        <p class="text-gray-600 dark:text-gray-400 mb-6 leading-relaxed">Get up and running with Solon in under a minute.</p>

        <h2 class="text-xl font-semibold mt-10 mb-4">Install</h2>
        <CodeBlock code="curl -fsSL https://getsolon.dev | sh" />

        <h2 class="text-xl font-semibold mt-10 mb-4">Start the server</h2>
        <p class="text-gray-600 dark:text-gray-400 mb-4 leading-relaxed">
          On first run, Solon automatically creates an admin API key and displays it.
          Save this key — it won't be shown again.
        </p>
        <CodeBlock code="solon serve" />

        <h2 class="text-xl font-semibold mt-10 mb-4">Pull a model</h2>
        <CodeBlock code="solon models pull llama3.2:3b" />

        <h2 class="text-xl font-semibold mt-10 mb-4">Make your first request</h2>
        <CodeBlock code={`curl http://localhost:8420/v1/chat/completions \\
  -H "Authorization: Bearer sol_sk_live_xxxx" \\
  -H "Content-Type: application/json" \\
  -d '{
    "model": "llama3.2:3b",
    "messages": [{"role": "user", "content": "Hello!"}]
  }'`} />

        <h2 class="text-xl font-semibold mt-10 mb-4">Open the dashboard</h2>
        <p class="text-gray-600 dark:text-gray-400 mb-4 leading-relaxed">
          Visit <code class="bg-gray-100 dark:bg-white/[0.06] px-1.5 py-0.5 rounded text-sm">http://localhost:8420</code> in your browser
          to access the built-in dashboard for managing models, API keys, and monitoring requests.
        </p>

        <h2 class="text-xl font-semibold mt-10 mb-4">Use with any OpenAI SDK</h2>
        <CodeBlock code={`from openai import OpenAI

client = OpenAI(
    base_url="http://localhost:8420/v1",
    api_key="sol_sk_live_xxxx",
)

response = client.chat.completions.create(
    model="llama3.2:3b",
    messages=[{"role": "user", "content": "Hello!"}],
)
print(response.choices[0].message.content)`} />
      </div>
    </div>
  </div>

  <Footer />
</Base>
