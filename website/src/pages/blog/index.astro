---
import Base from '../../layouts/Base.astro'
import Navbar from '../../components/Navbar.astro'
import Footer from '../../components/Footer.astro'
---

<Base title="Blog — Solon">
  <Navbar current="/blog" />

  <div class="max-w-3xl mx-auto px-6 pt-16 pb-32">
    <h1 class="text-4xl font-extrabold tracking-tight mb-12">Blog</h1>

    <a href="/blog/launch" class="block group">
      <article class="border border-gray-200 rounded-2xl p-8 hover:border-gray-300 transition-colors">
        <time class="text-sm text-gray-400">February 2026</time>
        <h2 class="text-2xl font-bold mt-2 mb-3 group-hover:text-brand transition-colors">
          Introducing Solon: Your AI. Your rules.
        </h2>
        <p class="text-gray-500 leading-relaxed">
          We built Solon because self-hosting AI should be easy and secure. Today we're launching
          the open-source runtime that makes it happen — one binary, mandatory auth, and secure tunnel access.
        </p>
      </article>
    </a>
  </div>

  <Footer />
</Base>
