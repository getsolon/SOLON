---
---

<section class="relative overflow-hidden">
  <div class="max-w-4xl mx-auto px-6 pt-24 pb-20 text-center">
    <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight leading-[1.1] mb-6">
      Your AI.<br />Your rules.
    </h1>
    <p class="text-lg md:text-xl text-gray-500 dark:text-gray-400 max-w-2xl mx-auto mb-10 leading-relaxed">
      Solon is a self-hosted AI runtime with mandatory auth, secure tunnel access,
      and an OpenAI-compatible API. One binary. No Docker. No dependencies.
    </p>

    <div class="inline-flex items-center gap-3 bg-gray-50 dark:bg-white/[0.05] border border-gray-200 dark:border-white/[0.08] rounded-xl px-5 py-3.5 font-mono text-sm">
      <code class="text-gray-800 dark:text-gray-200">curl -fsSL https://getsolon.dev | sh</code>
      <button
        onclick="navigator.clipboard.writeText('curl -fsSL https://getsolon.dev | sh')"
        class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 transition-colors"
        title="Copy"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="9" y="9" width="13" height="13" rx="2" />
          <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
        </svg>
      </button>
    </div>
    <p class="text-sm text-gray-400 dark:text-gray-500 mt-3">
      or <code class="bg-gray-100 dark:bg-white/[0.06] px-1.5 py-0.5 rounded text-xs">brew install solon</code>
    </p>

    <div class="flex gap-3 justify-center mt-12">
      <a href="/docs" class="px-6 py-2.5 bg-brand dark:bg-brand-light text-white rounded-lg text-sm font-semibold hover:opacity-90 transition-opacity">
        Get Started
      </a>
      <a href="https://github.com/openclaw/solon" class="px-6 py-2.5 border border-gray-200 dark:border-white/[0.1] rounded-lg text-sm font-semibold text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-white/[0.05] transition-colors">
        View on GitHub
      </a>
    </div>
  </div>
</section>
