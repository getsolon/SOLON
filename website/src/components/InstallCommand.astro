---

<section class="max-w-4xl mx-auto px-6 py-20">
  <div class="bg-brand dark:bg-brand-light/10 dark:border dark:border-brand-light/20 rounded-2xl p-12 text-center text-white">
    <h2 class="text-3xl font-bold mb-4">Ready to get started?</h2>
    <p class="text-gray-300 dark:text-gray-400 mb-8 max-w-lg mx-auto">Install Solon in seconds and start serving AI models securely.</p>

    <div class="inline-flex items-center gap-3 bg-white/10 border border-white/20 dark:border-white/10 rounded-xl px-6 py-4 font-mono text-sm">
      <code class="text-white dark:text-gray-200">curl -fsSL https://getsolon.dev | sh</code>
      <button
        onclick="navigator.clipboard.writeText('curl -fsSL https://getsolon.dev | sh')"
        class="text-white/50 hover:text-white transition-colors"
        title="Copy"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="9" y="9" width="13" height="13" rx="2" />
          <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
        </svg>
      </button>
    </div>
  </div>
</section>
