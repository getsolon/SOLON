---
---

<section class="max-w-4xl mx-auto px-6 py-20">
  <div class="bg-brand dark:bg-brand-light/10 dark:border dark:border-brand-light/20 rounded-2xl p-12 text-center text-white">
    <h2 class="text-3xl font-bold mb-4">Ready to deploy?</h2>
    <p class="text-gray-300 dark:text-gray-400 mb-8 max-w-lg mx-auto">Get a managed AI agent instance running in minutes. No infrastructure experience needed.</p>

    <div class="flex gap-3 justify-center mb-8">
      <a href="https://app.getsolon.dev" class="px-6 py-2.5 bg-white text-brand rounded-lg text-sm font-semibold hover:bg-gray-100 transition-colors">
        Deploy Managed Instance
      </a>
      <a href="/docs" class="px-6 py-2.5 border border-white/20 rounded-lg text-sm font-semibold text-white hover:bg-white/10 transition-colors">
        Read the Docs
      </a>
    </div>

    <div class="border-t border-white/10 pt-6">
      <p class="text-sm text-white/50 mb-3">Prefer to self-host?</p>
      <div class="inline-flex items-center gap-3 bg-white/10 border border-white/20 dark:border-white/10 rounded-xl px-6 py-3 font-mono text-sm">
        <code class="text-white dark:text-gray-200">curl -fsSL https://getsolon.dev/install.sh | sh</code>
        <button
          onclick="navigator.clipboard.writeText('curl -fsSL https://getsolon.dev/install.sh | sh')"
          class="text-white/50 hover:text-white transition-colors"
          title="Copy"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="9" y="9" width="13" height="13" rx="2" />
            <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>
