---
const { current = '' } = Astro.props

const links = [
  { href: '/docs', label: 'Docs' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/blog', label: 'Blog' },
]
---

<nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-lg border-b border-gray-100">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="text-xl font-extrabold tracking-tight text-brand">Solon</a>
    <div class="flex items-center gap-8">
      {links.map(link => (
        <a
          href={link.href}
          class={`text-sm font-medium ${current === link.href ? 'text-gray-900' : 'text-gray-500 hover:text-gray-900'} transition-colors`}
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://github.com/openclaw/solon"
        class="text-sm font-medium text-gray-500 hover:text-gray-900 transition-colors"
      >
        GitHub
      </a>
    </div>
  </div>
</nav>
