---
interface Props {
  name: string
  subtitle: string
  price: string
  per?: string
  features: string[]
  cta: string
  featured?: boolean
}

const { name, subtitle, price, per, features, cta, featured = false } = Astro.props
---

<div class={`rounded-2xl border p-8 ${featured ? 'border-brand ring-1 ring-brand' : 'border-gray-200'}`}>
  <h3 class="text-xl font-bold">{name}</h3>
  <p class="text-sm text-gray-500 mt-1">{subtitle}</p>
  <div class="mt-4 mb-6">
    <span class="text-4xl font-extrabold tracking-tight">{price}</span>
    {per && <span class="text-gray-400 text-sm">{per}</span>}
  </div>
  <a
    href={name === 'Enterprise' ? 'mailto:hello@solon.dev' : '/docs'}
    class={`block w-full text-center py-2.5 rounded-lg text-sm font-semibold transition-colors ${
      featured
        ? 'bg-brand text-white hover:opacity-90'
        : 'border border-gray-200 text-gray-700 hover:bg-gray-50'
    }`}
  >
    {cta}
  </a>
  <ul class="mt-6 space-y-2.5">
    {features.map(f => (
      <li class="text-sm text-gray-600 flex items-start gap-2">
        <span class="text-green-500 font-bold mt-0.5">&#10003;</span>
        {f}
      </li>
    ))}
  </ul>
</div>
