---
const rows = [
  { task: 'Provision a server', solon: '5 minutes', diy: '2-4 hours' },
  { task: 'Install AI runtime + auth + TLS', solon: 'Included', diy: '1-2 days' },
  { task: 'Connect WhatsApp/Slack/Telegram', solon: 'Dashboard toggle', diy: '1-2 weeks' },
  { task: 'Deploy open-source model', solon: 'One click', diy: '4-8 hours' },
  { task: 'Set up agent with tools', solon: 'Pre-configured', diy: '1-2 weeks' },
  { task: 'Security hardening + monitoring', solon: 'Included', diy: '1-2 days' },
  { task: 'Ongoing maintenance', solon: '$0 extra', diy: '$50-100K/yr engineer time' },
]
---

<section class="max-w-4xl mx-auto px-6 py-20">
  <h2 class="text-3xl font-bold text-center mb-4 tracking-tight">Solon vs. doing it yourself</h2>
  <p class="text-gray-500 dark:text-gray-400 text-center mb-12 max-w-xl mx-auto">Building your own AI agent infrastructure takes engineers and months. Or you can start in 5 minutes.</p>

  <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-white/[0.06]">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-gray-200 dark:border-white/[0.06]">
          <th class="text-left py-3 px-4 font-semibold text-gray-900 dark:text-gray-100">Task</th>
          <th class="text-center py-3 px-4 font-semibold text-brand-light">Solon</th>
          <th class="text-center py-3 px-4 font-semibold text-gray-900 dark:text-gray-100">DIY</th>
        </tr>
      </thead>
      <tbody>
        {rows.map(row => (
          <tr class="border-b border-gray-100 dark:border-white/[0.04]">
            <td class="py-3 px-4 text-gray-700 dark:text-gray-300">{row.task}</td>
            <td class="text-center py-3 px-4 text-green-600 dark:text-green-400 font-medium">{row.solon}</td>
            <td class="text-center py-3 px-4 text-gray-500 dark:text-gray-400">{row.diy}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>
