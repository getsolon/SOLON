# {{ ansible_managed }}
# Docker Compose for vLLM with Nemotron model
# NemoClaw GPU inference setup

services:
  vllm:
    image: {{ vllm_image }}
    container_name: vllm-inference
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ vllm_port }}:8000"
    volumes:
      - /opt/vllm/model-cache:/root/.cache/huggingface
    environment:
      - HUGGING_FACE_HUB_TOKEN={{ vllm_hf_token | default('') }}
    command:
      - "--model"
      - "{{ vllm_model }}"
      - "--tensor-parallel-size"
      - "{{ vllm_tensor_parallel_size }}"
      - "--gpu-memory-utilization"
      - "{{ vllm_gpu_memory_utilization }}"
      - "--max-model-len"
      - "{{ vllm_max_model_len }}"
      - "--host"
      - "0.0.0.0"
      - "--port"
      - "8000"
{% if vllm_extra_args is defined and vllm_extra_args | length > 0 %}
{% for arg in vllm_extra_args %}
      - "{{ arg }}"
{% endfor %}
{% endif %}
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
    ipc: host
    ulimits:
      memlock:
        soft: -1
        hard: -1
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 120s
