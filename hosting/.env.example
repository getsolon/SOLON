# LibSQL / Turso database URL
# For local development: file:local.db
# For production: libsql://your-db.turso.io
DATABASE_URL=file:local.db

# Better Auth secret key for signing sessions/tokens
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Stripe API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Hetzner Cloud API token for server provisioning
HETZNER_API_TOKEN=

# AES-256 encryption key for storing tenant API keys at rest
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Public-facing application URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
